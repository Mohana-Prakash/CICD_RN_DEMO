# Dependencies
node_modules/

# React Native
.expo/
.expo-shared/

# Android — ignore only generated/local files, not the project itself
android/.gradle/
android/app/build/
*.keystore
!debug.keystore

# Fastlane — ignore generated reports and Bundler's local gem cache
android/fastlane/report.xml
android/fastlane/README.md
android/vendor/

# Firebase — both files are written at runtime from CI secrets, never committed
android/firebase-service-account.json
android/app/google-services.json

# iOS — ignore only generated/local files, not the project itself
ios/Pods/
ios/build/

# Build output
build/
dist/

# Metro
.metro-health-check*

# Misc
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.local
.env.*.local

# TypeScript
*.tsbuildinfo

# VSCode
.vscode/
